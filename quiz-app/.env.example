# Copy to ../.env (next to docker-compose.yml) and fill in.
# Generate a strong secret: `openssl rand -hex 32`
QUIZ_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Either a bcrypt hash (preferred) or a plaintext password.
# Generate: `docker compose run --rm quiz npm run hash-password -- 'my password'`
QUIZ_ADMIN_PASSWORD_HASH=
QUIZ_ADMIN_PASSWORD=changeme123

QUIZ_DB_PASSWORD=changeme-db-pass
